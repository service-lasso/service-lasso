{
  "name": "service-lasso",
  "version": "0.1.0",
  "private": true,
  "description": "Core runtime and contract repository for Service Lasso.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test tests/**/*.test.js",
    "dev": "npm run build && node --enable-source-maps dist/index.js",
    "start": "node --enable-source-maps dist/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2"
  }
}